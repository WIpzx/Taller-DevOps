// ============================================================
// Job:  taller_devops_api_dev   (DEV — ramas feature/**)
// Pipeline: Checkout -> Sonar -> Quality Gate -> Build -> Deploy -> ps -> logs
// Despliega el API en el entorno DEV (API host:3001) con docker-compose.dev.yml
// Requiere en Jenkins:
//   - Servidor SonarQube llamado 'SonarQube' (URL http://sonarqube:9000  <- nombre de servicio, sin '_')
//   - Webhook en SonarQube -> http://jenkins:8080/sonarqube-webhook/
//   - Herramienta 'sonar-scanner' en PATH (incluida en la imagen jenkins/Dockerfile)
// ============================================================
pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  environment {
    APP_NAME          = 'taller_devops'
    SONAR_PROJECT_KEY = 'taller_devops_api'
    COMPOSE_FILE      = 'docker-compose.dev.yml'
    ENV_FILE          = '.env.dev'
  }

  stages {
    stage('Descargar codigo fuente') {
      steps {
        // Limpieza inicial para evitar workspace corrupto
        deleteDir()
        checkout scm
        sh 'git fetch --all --tags || true'
        sh 'git checkout feature/taller2 || git checkout -B feature/taller2 origin/feature/taller2'
        sh 'git log -1 --oneline || true'
      }
    }

    stage('Analisis SonarQube') {
      steps {
        dir('bezkoder-api') {
          // Cobertura real con jest (Node 16 incluido en la imagen de Jenkins)
          sh 'if [ -f package-lock.json ]; then rm -rf node_modules && npm ci --no-audit --no-fund; else rm -rf node_modules && npm install --no-audit --no-fund --legacy-peer-deps --no-fund; fi'
          sh 'npm run test:ci'
          withSonarQubeEnv('SonarQube') {
            sh 'sonar-scanner -Dsonar.projectKey=${SONAR_PROJECT_KEY}'
          }
        }
      }
    }

    stage('Validar Quality Gate') {
      steps {
        timeout(time: 10, unit: 'MINUTES') {
          // Si el Quality Gate falla, aborta el pipeline (job FAILED) y NO despliega.
          waitForQualityGate abortPipeline: true
        }
      }
    }

    stage('Compilar solucion') {
      steps {
        sh '[ -f ${ENV_FILE} ] || cp .env.dev.example ${ENV_FILE}'
        sh 'docker compose --env-file ${ENV_FILE} -f ${COMPOSE_FILE} build api_dev'
      }
    }

    stage('Desplegar solucion') {
      steps {
        sh 'docker compose --env-file ${ENV_FILE} -f ${COMPOSE_FILE} up -d mysqldb_dev api_dev'
      }
    }

    stage('Mostrar contenedores') {
      steps {
        sh 'docker ps --filter "name=taller_devops_" --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}"'
      }
    }

    stage('Mostrar logs') {
      steps {
        sh 'docker compose --env-file ${ENV_FILE} -f ${COMPOSE_FILE} logs --tail=60 api_dev || true'
      }
    }
  }

  post {
    success { echo "DEV API desplegado. API: http://localhost:3001/api/tutorials" }
    failure { echo 'Pipeline DEV API FALLIDO (revisa Quality Gate, tests o build). No se desplegó.' }
  }
}
